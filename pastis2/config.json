{
  "layers": {
    "sentinel2": {
      "type": "raster",
      "band_sets": [
        {
          "bands": [
            "B02",
            "B03",
            "B04",
            "B05",
            "B06",
            "B07",
            "B08",
            "B8A",
            "B11",
            "B12"
          ],
          "dtype": "uint16",
          "nodata_value": 0
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.planetary_computer.Sentinel2",
        "ingest": false,
        "init_args": {
          "harmonize": true,
          "query": {
            "eo:cloud_cover": {
              "lt": 70
            }
          },
          "sort_by": "eo:cloud_cover"
        },
        "query_config": {
          "space_mode": "MOSAIC",
          "period_duration": "30d",
          "max_matches": 12
        }
      }
    },
    "crop_parcels": {
      "type": "vector",
      "data_source": {
        "class_path": "rslearn.data_sources.local_files.LocalFiles",
        "init_args": {
          "src_dir": "data/rpg"
        }
      }
    },
    "label": {
      "type": "raster",
      "band_sets": [
        {
          "bands": [
            "class_id"
          ],
          "dtype": "uint8",
          "nodata_value": 255
        }
      ]
    }
  }
}