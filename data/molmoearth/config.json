{
  "layers": {
    "sentinel2": {
      "band_sets": [
        {
          "bands": [
            "B01",
            "B09"
          ],
          "dtype": "uint16",
          "zoom_offset": -2
        },
        {
          "bands": [
            "B02",
            "B03",
            "B04",
            "B08"
          ],
          "dtype": "uint16"
        },
        {
          "bands": [
            "B05",
            "B06",
            "B07",
            "B8A",
            "B11",
            "B12"
          ],
          "dtype": "uint16",
          "zoom_offset": -1
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.aws_sentinel2_element84.Sentinel2",
        "ingest": false,
        "init_args": {
          "sort_by": "eo:cloud_cover"
        },
        "query_config": {
          "max_matches": 6,
          "min_matches": 1,
          "period_duration": "60d",
          "space_mode": "PER_PERIOD_MOSAIC"
        }
      },
      "type": "raster"
    }
  }
}
