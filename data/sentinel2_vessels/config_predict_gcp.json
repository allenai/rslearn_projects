{
  "layers": {
    "label": {
      "type": "vector"
    },
    "mask": {
      "band_sets": [
        {
          "bands": [
            "mask"
          ],
          "dtype": "uint8",
          "format": {
            "class_path": "rslearn.utils.raster_format.SingleImageRasterFormat",
            "init_args": {
              "format": "png"
            }
          }
        }
      ],
      "type": "raster"
    },
    "output": {
      "type": "vector"
    },
    "sentinel2": {
      "band_sets": [
        {
          "bands": [
            "B02",
            "B03",
            "B04",
            "B08"
          ],
          "dtype": "uint16",
          "format": {
            "class_path": "rslearn.utils.raster_format.GeotiffRasterFormat",
            "init_args": {
              "geotiff_options": {
                "compress": "zstd",
                "predictor": 2,
                "zstd_level": 1
              }
            }
          }
        },
        {
          "bands": [
            "B05",
            "B06",
            "B07",
            "B8A",
            "B11",
            "B12"
          ],
          "dtype": "uint16",
          "zoom_offset": -1
        },
        {
          "bands": [
            "B01",
            "B09",
            "B10"
          ],
          "dtype": "uint16",
          "zoom_offset": -2
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.gcp_public_data.Sentinel2",
        "init_args": {
          "harmonize": true,
          "index_cache_dir": "cache/sentinel2",
          "use_rtree_index": false
        }
      },
      "type": "raster"
    }
  }
}
