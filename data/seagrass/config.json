{
  "layers": {
    "label_raster": {
      "band_sets": [
        {
          "bands": [
            "label"
          ],
          "dtype": "uint8",
          "format": {
            "always_enable_tiling": true,
            "name": "geotiff"
          },
          "nodata_value": 255
        }
      ],
      "class_names": [
        "background",
        "sparse_seagrass",
        "dense_seagrass"
      ],
      "class_property_name": "label",
      "type": "raster"
    },
    "sentinel2": {
      "band_sets": [
        {
          "bands": [
            "B02",
            "B03",
            "B04",
            "B08"
          ],
          "dtype": "uint16",
          "format": {
            "always_enable_tiling": true,
            "name": "geotiff"
          }
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.gcp_public_data.Sentinel2",
        "duration": "180d",
        "init_args": {
          "harmonize": true,
          "index_cache_dir": "cache/sentinel2",
          "sort_by": "cloud_cover",
          "use_rtree_index": false
        },
        "query_config": {
          "max_matches": 6,
          "space_mode": "CONTAINS"
        },
        "time_offset": "-90d"
      },
      "type": "raster"
    }
  },
  "tile_store": {
    "class_path": "rslearn.tile_stores.default.DefaultTileStore",
    "init_args": {
      "path_suffix": "tiles"
    }
  }
}
