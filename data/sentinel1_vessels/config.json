{
  "layers": {
    "label": {
      "type": "vector"
    },
    "mask": {
      "band_sets": [
        {
          "bands": [
            "mask"
          ],
          "dtype": "uint8",
          "format": {
            "class_path": "rslearn.utils.raster_format.SingleImageRasterFormat",
            "init_args": {
              "format": "png"
            }
          }
        }
      ],
      "type": "raster"
    },
    "output": {
      "type": "vector"
    },
    "sentinel1": {
      "alias": "sentinel1",
      "band_sets": [
        {
          "bands": [
            "vv",
            "vh"
          ],
          "dtype": "float32"
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.aws_sentinel1.Sentinel1"
      },
      "resampling_method": "cubic",
      "type": "raster"
    },
    "sentinel1_historical": {
      "alias": "sentinel1",
      "band_sets": [
        {
          "bands": [
            "vv",
            "vh"
          ],
          "dtype": "float32"
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.aws_sentinel1.Sentinel1",
        "duration": "60d",
        "init_args": {
          "orbit_direction": "ASCENDING"
        },
        "query_config": {
          "max_matches": 2
        },
        "time_offset": "-90d"
      },
      "resampling_method": "cubic",
      "type": "raster"
    }
  }
}
